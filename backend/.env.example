# Copy to .env and set values. Used by the FastAPI app.

# App (optional – defaults shown)
POC_APP_NAME=Data Enrichment → BigCommerce
POC_CORS_ORIGINS=*

# Logging: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Required for AI flow: column mapping + product finder (web search result → structured data)
OPENAI_API_KEY=sk-your-key-here

# Required for AI product finder: web search (Tavily). Get key at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# BigCommerce API (for direct import; optional but required if you enable imports)
# Find these in BigCommerce control panel under Advanced Settings → API Accounts.
BIGCOMMERCE_STORE_HASH=your_store_hash_here
BIGCOMMERCE_ACCESS_TOKEN=your_api_token_here
BIGCOMMERCE_API_BASE_URL=https://api.bigcommerce.com
